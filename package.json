{
  "name": "claude-consult-mcp",
  "version": "0.12.0",
  "description": "MCP stdio server that lets OpenAI Codex consult local Claude Code for co-analysis, second opinions, and read-only file review",
  "type": "module",
  "license": "MIT",
  "author": "Chao-Shiun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Chao-Shiun/claude-consult-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Chao-Shiun/claude-consult-mcp/issues"
  },
  "homepage": "https://github.com/Chao-Shiun/claude-consult-mcp#readme",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "claude-consult-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "codex",
    "claude",
    "claude-code",
    "second-opinion",
    "code-review",
    "ai"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run build && npm run test"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cross-spawn": "^7.0.6",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^20.19.0",
    "@vitest/coverage-v8": "^3.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
